{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "scaffold_tentacle",
        "description": "Generate a new skill_tentacle package structure",
        "parameters": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "Tentacle name (kebab-case)" },
            "purpose": { "type": "string", "description": "One-line description of what it does" },
            "runtime": { "type": "string", "enum": ["python", "typescript"], "default": "python" }
          },
          "required": ["name", "purpose"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "validate_tentacle",
        "description": "Validate a skill_tentacle package for correctness",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "Path to tentacle directory" }
          },
          "required": ["path"]
        }
      }
    }
  ]
}
