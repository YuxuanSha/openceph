{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "fetch_hn_stories",
        "description": "Fetch top stories from Hacker News with minimum comment threshold",
        "parameters": {
          "type": "object",
          "properties": {
            "min_comments": { "type": "integer", "description": "Minimum comment count", "default": 100 },
            "limit": { "type": "integer", "description": "Max stories to fetch", "default": 30 }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "score_story",
        "description": "Score a story's engineering relevance using LLM",
        "parameters": {
          "type": "object",
          "properties": {
            "title": { "type": "string", "description": "Story title" },
            "url": { "type": "string", "description": "Story URL" },
            "text": { "type": "string", "description": "Story text/summary" }
          },
          "required": ["title"]
        }
      }
    }
  ]
}
