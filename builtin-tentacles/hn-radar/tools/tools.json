[
  {
    "type": "function",
    "function": {
      "name": "websearch",
      "description": "通过 Jina Search API 搜索网页。返回搜索结果列表，每条包含标题、URL、内容摘要。用于补充信息或回答 Brain 追问。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "搜索关键词，尽量简洁精准"
          },
          "max_results": {
            "type": "integer",
            "description": "最大返回结果数",
            "default": 5
          }
        },
        "required": ["query"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "webfetch",
      "description": "通过 Jina Reader API 抓取指定 URL 的网页内容，返回干净的 Markdown 文本。用于深度阅读 HN 帖子链接的原始文章。",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "要抓取的网页 URL"
          },
          "max_chars": {
            "type": "integer",
            "description": "最大返回字符数（截断过长的页面）",
            "default": 8000
          }
        },
        "required": ["url"]
      }
    }
  }
]