// OpenCeph 配置文件 - 修改后无需重启（热重载）
// 凭据请用 "from:credentials/<name>" 引用，不要直接写在这里
{
  "meta": { "version": "3.2" },

  "gateway": {
    "port": 18790,
    "bind": "loopback",
    "auth": { "mode": "token", "token": "from:credentials/gateway_token" }
  },

  "agents": {
    "defaults": {
      "workspace": "~/.openceph/workspace",
      "model": {
        "primary": "anthropic/claude-sonnet-4-5",
        "fallbacks": ["openai/gpt-4o"]
      },
      "userTimezone": "UTC"
    }
  },

  "auth": {
    "profiles": {
      "openrouter:primary": {
        "mode": "api_key",
        "apiKey": "from:credentials/openrouter"
      }
    },
    "order": { "openrouter": ["openrouter:primary"] }
  },

  "session": {
    "reset": { "mode": "daily", "atHour": 4, "idleMinutes": 120 }
  },

  "mcp": {
    "servers": {},
    "webSearch": { "cacheTtlMinutes": 15 },
    "webFetch": { "maxCharsCap": 50000 }
  },

  "skills": {
    "paths": ["~/.openceph/workspace/skills", "~/.openceph/skills"]
  },

  "builtinTentacles": {
    "autoInstallOnInit": true,
    "autoUpgradeOnUpdate": true,
    "skipList": []
  },

  "tentacle": {
    "maxActive": 20,
    "ipcSocketPath": "~/.openceph/openceph.sock",
    "codeGenMaxRetries": 3,
    "crashRestartMaxAttempts": 3,
    "model": {
      "primary": "openrouter/anthropic/claude-haiku-4-5",
      "fallbacks": []
    },
    "models": {
      "openrouter/anthropic/claude-haiku-4-5": {
        "alias": "TentacleFast",
        "params": {
          "temperature": 0.2
        }
      }
    },
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "api": "openai-completions"
      }
    },
    "auth": {
      "profiles": {
        "openrouter:tentacle": {
          "mode": "api_key",
          "apiKey": "from:credentials/openrouter"
        }
      },
      "order": { "openrouter": ["openrouter:tentacle"] }
    },
    "confidenceThresholds": {
      "directReport": 0.8,
      "consultation": 0.4,
      "discard": 0.0
    }
  },

  "heartbeat": {
    "every": "24h",
    "target": "none",
    "checkAfterTurns": 100,
    "activeHours": {
      "start": "08:00",
      "end": "23:00"
    }
  },

  "cron": {
    "enabled": true,
    "store": "~/.openceph/cron/jobs.json",
    "timezone": "UTC",
    "maxConcurrentRuns": 1,
    "sessionRetention": "24h",
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000]
    },
    "isolatedSessionRetention": "7d",
    "runLog": {
      "maxBytes": 5242880,
      "keepLines": 500
    }
  },

  "push": {
    "defaultTiming": "best_time",
    "preferredWindowStart": "09:00",
    "preferredWindowEnd": "10:00",
    "maxDailyPushes": 5,
    "consolidate": true,
    "dedup": {
      "byUrl": true,
      "bySimilarity": true,
      "similarityThreshold": 0.8
    },
    "feedback": {
      "enabled": true,
      "ignoreWindowHours": 24
    },
    "fallbackDigestTime": "09:00",
    "fallbackDigestTz": "UTC"
  },

  "plugins": {
    "autoDiscover": true,
    "allowedPackageScopes": ["@openceph", "@openceph-skills"]
  },

  "tools": {
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 10,
      "criticalThreshold": 20,
      "historySize": 30,
      "detectors": {
        "genericRepeat": true,
        "knownPollNoProgress": true,
        "pingPong": true
      }
    }
  },

  "logging": { "level": "INFO" },
  "cost": { "dailyLimitUsd": 0.5 }
}
